{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "helixagent": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Helix Agent",
      "options": {
        "baseURL": "http://localhost:8100/v1",
        "apiKey": "sk-e890e68da3c98427dbf8e8fc5044a4054413110d9db0d17d50c20639bf55e78d"
      },
      "models": {
        "helix-debate": {
          "name": "Helix AI Debate Ensemble",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "helix-llm": {
          "name": "Helix LLM",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  },
  "agent": {
    "coder": {
      "model": "helixagent/helix-debate",
      "maxTokens": 8192,
      "options": {
        "maxTokens": 8192
      },
      "permission": {}
    },
    "summarizer": {
      "model": "helixagent/helix-debate",
      "maxTokens": 4096,
      "options": {
        "maxTokens": 4096
      },
      "permission": {}
    },
    "task": {
      "model": "helixagent/helix-llm",
      "maxTokens": 4096,
      "options": {
        "maxTokens": 4096
      },
      "permission": {}
    },
    "title": {
      "model": "helixagent/helix-llm",
      "maxTokens": 80,
      "options": {
        "maxTokens": 80
      },
      "permission": {}
    }
  },
