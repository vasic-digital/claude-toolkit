{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "helixagent": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Helix Agent",
      "options": {
        "baseURL": "http://localhost:8100/v1",
        "apiKey": "sk-e890e68da3c98427dbf8e8fc5044a4054413110d9db0d17d50c20639bf55e78d"
      },
      "models": {
        "helix-debate": {
          "name": "Helix AI Debate Ensemble",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "helix-llm": {
          "name": "Helix LLM",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  },
  "agent": {
    "coder": {
      "model": "helixagent/helix-debate",
      "maxTokens": 8192,
      "options": {
        "maxTokens": 8192
      },
      "permission": {}
    },
    "summarizer": {
      "model": "helixagent/helix-debate",
      "maxTokens": 4096,
      "options": {
        "maxTokens": 4096
      },
      "permission": {}
    },
    "task": {
      "model": "helixagent/helix-llm",
      "maxTokens": 4096,
      "options": {
        "maxTokens": 4096
      },
      "permission": {}
    },
    "title": {
      "model": "helixagent/helix-llm",
      "maxTokens": 80,
      "options": {
        "maxTokens": 80
      },
      "permission": {}
    }
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/sse"
    },
    "commands": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-commands"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "docker": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-docker"
      ]
    },
    "everything": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    "fetch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-fetch-server"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/milosvasic"
      ]
    },
    "git": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-git"
      ]
    },
    "markdown": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-markdown"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "environment": {
        "NOTION_API_KEY": ""
      }
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://helixagent:helixagent123@localhost:15432/helixagent_db"
      ]
    },
    "puppeteer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "shell": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-shell-server"
      ]
    },
    "sqlite": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-sqlite-npx",
        "/tmp/helixagent.db"
      ]
    },
    "tavily": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tavily-mcp"
      ],
      "environment": {
        "TAVILY_API_KEY": ""
      }
    },
    "time": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@theo.foobar/mcp-time"
      ]
    }
  },
  "plugin": [
    "opencode-agent-skills@0.6.5"
  ],
  "plugin_origins": [
    {
      "spec": "opencode-agent-skills@0.6.5",
      "source": "/Users/milosvasic/.config/opencode",
      "scope": "global"
    }
  ],
  "mode": {},
  "command": {},
  "username": "milosvasic"
}
